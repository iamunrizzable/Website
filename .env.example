# TikTok App credentials (from developers.tiktok.com)
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
TIKTOK_REDIRECT_URI=https://tjbmanagementinc.com/auth/tiktok/callback

# Admin panel password — set this in Vercel Environment Variables
ADMIN_SECRET=your_strong_secret_here

# Vercel KV (add KV store in Vercel dashboard → Storage → KV, then pull env)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Email alerts via SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tyler@tjbmanagementinc.com
SMTP_PASS=your_gmail_app_password
